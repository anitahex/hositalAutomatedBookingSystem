DATABASE_URL=postgresql://postgres:password@localhost:5432/hospital_db
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXP_SECONDS=604800

HF_TOKEN=your_hugging_face_token
HF_MODEL=Qwen/Qwen3.6-35B-A3B
HF_ROUTER_MODEL=Qwen/Qwen3.6-35B-A3B
HF_TIMEOUT_SECONDS=30
HF_ROUTER_TIMEOUT_SECONDS=8
HF_MAX_TOKENS=512
HF_ROUTER_MAX_TOKENS=180
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local embedded Qdrant, no Docker/server required.
QDRANT_MODE=local
QDRANT_LOCAL_PATH=qdrant_storage

# Remote Qdrant Cloud alternative.
QDRANT_URL=https://your-cluster-url.qdrant.tech
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=clinical_knowledge_base
VECTOR_SIZE=384
